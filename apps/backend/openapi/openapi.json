  "info": {
    "title": "Tarhib API",
    "description": "Contrat API — source de vérité pour la génération du client Dart mobile",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateCompanyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Sonatrach SA"
          },
          "slug": {
            "type": "string",
            "example": "sonatrach-sa",
            "description": "Identifiant URL-safe unique (kebab-case)"
          }
        },
        "required": [
          "name",
          "slug"
        ]
      },
      "CompanyDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
          },
          "name": {
            "type": "string",
            "example": "Sonatrach SA"
          },
          "slug": {
            "type": "string",
            "example": "sonatrach-sa"
          },
          "active": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "active"
        ]
      },
      "CreateBranchDto": {
        "type": "object",
        "properties": {
          "companyId": {
            "type": "string",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0854"
          },
          "nameAr": {
            "type": "string",
            "example": "فرع الجزائر العاصمة"
          },
          "nameEn": {
            "type": "string",
            "example": "Algiers HQ"
          }
        },
        "required": [
          "companyId",
          "nameAr",
          "nameEn"
        ]
      },
      "BranchDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
          },
          "companyId": {
            "type": "string",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0854"
          },
