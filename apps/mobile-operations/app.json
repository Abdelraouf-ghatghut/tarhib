{
  "expo": {
    "name": "Tarhib Operations",
    "slug": "tarhib-operations",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "tarhib-operations",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tarhib.operations",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Tarhib uses notifications for assigned operational tasks and urgent incidents."
      }
    },
    "android": {
      "package": "com.tarhib.operations",
      "permissions": ["POST_NOTIFICATIONS"],
      "adaptiveIcon": {
        "backgroundColor": "#F7F8FC"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      ["expo-notifications", { "color": "#4056D6", "defaultChannel": "operations" }]
    ]
  }
}
